{
  "id": "midi_inject_test",
  "name": "MIDI Inject Test",
  "abbrev": "M2M",
  "version": "0.3.0",
  "description": "Direct MIDI pass-through to Move injection (aftertouch filtered)",
  "dsp": "dsp.so",
  "api_version": 2,
  "standalone": false,
  "capabilities": {
    "audio_out": true,
    "midi_in": true,
    "chainable": true,
    "component_type": "sound_generator",
    "ui_hierarchy": {
      "levels": {
        "root": {
          "name": "MIDI Inject Test",
          "params": [
            {
              "key": "out_channel",
              "name": "Output Ch",
              "type": "int",
              "min": 0,
              "max": 16,
              "default": 0,
              "step": 1
            },
            {
              "key": "source_mode",
              "name": "Input Src",
              "type": "enum",
              "options": ["both", "internal", "external"],
              "default": 2
            }
          ],
          "knobs": ["out_channel", "source_mode"]
        }
      }
    }
  }
}
