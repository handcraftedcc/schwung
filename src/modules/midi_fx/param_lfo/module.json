{
  "id": "param_lfo",
  "name": "Param LFO",
  "abbrev": "LF",
  "version": "0.2.0",
  "builtin": true,
  "capabilities": {
    "chainable": true,
    "component_type": "midi_fx",
    "ui_hierarchy": {
      "levels": {
        "root": {
          "name": "Param LFO",
          "params": [
            { "level": "lfo1", "label": "LFO 1" },
            { "level": "lfo2", "label": "LFO 2" },
            { "level": "lfo3", "label": "LFO 3" }
          ],
          "knobs": [
            "lfo1_enable",
            "lfo2_enable",
            "lfo3_enable",
            "lfo1_rate_hz",
            "lfo2_rate_hz",
            "lfo3_rate_hz",
            "lfo1_depth",
            "lfo2_depth"
          ]
        },
        "lfo1": {
          "name": "LFO 1",
          "params": [
            { "key": "lfo1_enable", "name": "Enable", "type": "enum", "options": ["off", "on"], "default": 0 },
            { "key": "lfo1_waveform", "name": "Wave", "type": "enum", "options": ["sine", "triangle", "square", "saw_up", "random", "drunk"], "default": 0 },
            { "key": "lfo1_rate_hz", "name": "Rate", "type": "float", "min": 0.01, "max": 20.0, "default": 1.0, "step": 0.01 },
            { "key": "lfo1_phase", "name": "Phase", "type": "float", "min": 0.0, "max": 1.0, "default": 0.0, "step": 0.01 },
            { "key": "lfo1_depth", "name": "Depth", "type": "float", "min": 0.0, "max": 1.0, "default": 0.25, "step": 0.01 },
            { "key": "lfo1_offset", "name": "Offset", "type": "float", "min": -1.0, "max": 1.0, "default": 0.0, "step": 0.01 },
            { "key": "lfo1_polarity", "name": "Polarity", "type": "enum", "options": ["bipolar", "unipolar"], "default": 0 },
            { "key": "lfo1_retrigger", "name": "Retrigger", "type": "enum", "options": ["off", "on"], "default": 0 },
            { "key": "lfo1_target_component", "name": "Target Comp", "type": "enum", "options": ["synth", "fx1", "fx2", "midi_fx1", "midi_fx2"], "default": 0 },
            { "key": "lfo1_target_param", "name": "Target Param", "type": "filepath", "default": "" }
          ],
          "knobs": ["lfo1_enable", "lfo1_waveform", "lfo1_rate_hz", "lfo1_phase", "lfo1_depth", "lfo1_offset", "lfo1_polarity", "lfo1_retrigger"]
        },
        "lfo2": {
          "name": "LFO 2",
          "params": [
            { "key": "lfo2_enable", "name": "Enable", "type": "enum", "options": ["off", "on"], "default": 0 },
