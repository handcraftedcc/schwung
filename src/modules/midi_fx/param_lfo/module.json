            { "key": "lfo2_rate_hz", "name": "Rate", "type": "float", "min": 0.01, "max": 20.0, "default": 1.0, "step": 0.01 },
            { "key": "lfo2_phase", "name": "Phase", "type": "float", "min": 0.0, "max": 1.0, "default": 0.0, "step": 0.01 },
            { "key": "lfo2_depth", "name": "Depth", "type": "float", "min": 0.0, "max": 1.0, "default": 0.25, "step": 0.01 },
            { "key": "lfo2_offset", "name": "Offset", "type": "float", "min": -1.0, "max": 1.0, "default": 0.0, "step": 0.01 },
            { "key": "lfo2_polarity", "name": "Polarity", "type": "enum", "options": ["bipolar", "unipolar"], "default": 0 },
            { "key": "lfo2_retrigger", "name": "Retrigger", "type": "enum", "options": ["off", "on"], "default": 0 },
            { "key": "lfo2_target_component", "name": "Target Comp", "type": "enum", "options": ["synth", "fx1", "fx2", "midi_fx1", "midi_fx2"], "default": 0 },
            { "key": "lfo2_target_param", "name": "Target Param", "type": "filepath", "default": "" }
          ],
          "knobs": ["lfo2_enable", "lfo2_waveform", "lfo2_rate_hz", "lfo2_phase", "lfo2_depth", "lfo2_offset", "lfo2_polarity", "lfo2_retrigger"]
        },
        "lfo3": {
          "name": "LFO 3",
          "params": [
            { "key": "lfo3_enable", "name": "Enable", "type": "enum", "options": ["off", "on"], "default": 0 },
