            { "key": "lfo3_rate_hz", "name": "Rate", "type": "float", "min": 0.01, "max": 20.0, "default": 1.0, "step": 0.01 },
            { "key": "lfo3_phase", "name": "Phase", "type": "float", "min": 0.0, "max": 1.0, "default": 0.0, "step": 0.01 },
            { "key": "lfo3_depth", "name": "Depth", "type": "float", "min": 0.0, "max": 1.0, "default": 0.25, "step": 0.01 },
            { "key": "lfo3_offset", "name": "Offset", "type": "float", "min": -1.0, "max": 1.0, "default": 0.0, "step": 0.01 },
            { "key": "lfo3_polarity", "name": "Polarity", "type": "enum", "options": ["bipolar", "unipolar"], "default": 0 },
            { "key": "lfo3_retrigger", "name": "Retrigger", "type": "enum", "options": ["off", "on"], "default": 0 },
            { "key": "lfo3_target_component", "name": "Target Comp", "type": "enum", "options": ["synth", "fx1", "fx2", "midi_fx1", "midi_fx2"], "default": 0 },
            { "key": "lfo3_target_param", "name": "Target Param", "type": "filepath", "default": "" }
          ],
          "knobs": ["lfo3_enable", "lfo3_waveform", "lfo3_rate_hz", "lfo3_phase", "lfo3_depth", "lfo3_offset", "lfo3_polarity", "lfo3_retrigger"]
        }
      }
    }
  }
}
